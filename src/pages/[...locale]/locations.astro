---
import { getCollection, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getLocalizedStaticPaths } from "../../i18n/utils";

export const getStaticPaths = async () => {
    const pages = await getCollection("pages", ({ id }) =>
        id.endsWith("locations"),
    );

    return getLocalizedStaticPaths({ page: pages });
};

const { page } = Astro.props;

const { Content } = await render(page!);
---

<style>
    figure {
        display: flex;
        flex-wrap: wrap;
        align-items: flex-start;
        gap: var(--space-lg);
        margin-bottom: var(--space-md);

        img {
            min-width: 20rem;
            width: 30%;
        }

        figcaption {
            flex: 1;

            ul {
                li {
                    margin-bottom: var(--space-sm);
                }
            }
        }
    }
</style>

<BaseLayout pageTitle="Verkaufsstellen">
    <Content />

    <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3429.142502675869!2d8.509136999999999!3d47.6052707!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x479071c9fb06519b%3A0x65db66735665465e!2sRonkies%20Glace!5e1!3m2!1sde!2sch!4v1775758042851!5m2!1sde!2sch"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen=""
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"></iframe>
</BaseLayout>
